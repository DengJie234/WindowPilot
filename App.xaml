<Application x:Class="WindowPilot.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:WindowPilot.Converters"
             xmlns:views="clr-namespace:WindowPilot.Views"
             xmlns:vm="clr-namespace:WindowPilot.ViewModels"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/Colors.xaml"/>
                <ResourceDictionary Source="Styles/Typography.xaml"/>
                <ResourceDictionary Source="Styles/Cards.xaml"/>
                <ResourceDictionary Source="Styles/Buttons.xaml"/>
                <ResourceDictionary Source="Styles/TextBoxes.xaml"/>
                <ResourceDictionary Source="Styles/DataGrid.xaml"/>
                <ResourceDictionary Source="Styles/Tags.xaml"/>
                <ResourceDictionary Source="Styles/Navigation.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
            <conv:BoolToStatusTextConverter x:Key="BoolToStatusText"/>
            <conv:OpacityToPercentConverter x:Key="OpacityToPercent"/>
            <conv:WindowStateToTagConverter x:Key="WindowStateToTag"/>
            <conv:StringEqualsConverter x:Key="StringEquals"/>
            <conv:InverseBoolConverter x:Key="InverseBool"/>

            <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
                <views:DashboardPage/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:WindowsViewModel}">
                <views:WindowsPage/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:LayoutsViewModel}">
                <views:LayoutsPage/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:RulesViewModel}">
                <views:RulesPage/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:MiniWindowPageViewModel}">
                <views:MiniWindowPage/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:GroupsPageViewModel}">
                <views:GroupsPage/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:HotkeysViewModel}">
                <views:HotkeysPage/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                <views:SettingsPage/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:AboutPageViewModel}">
                <views:AboutPage/>
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
