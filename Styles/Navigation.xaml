<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="NavRadioButton" TargetType="{x:Type RadioButton}">
        <Setter Property="Height" Value="44"/>
        <Setter Property="Margin" Value="12,3"/>
        <Setter Property="Padding" Value="16,0"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource SidebarItemForegroundBrush}"/>
        <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RadioButton}">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <Border x:Name="Indicator"
                                    Width="4"
                                    HorizontalAlignment="Left"
                                    Margin="0,9,0,9"
                                    CornerRadius="2"
                                    Background="Transparent"/>
                            <TextBlock Margin="{TemplateBinding Padding}"
                                       VerticalAlignment="Center"
                                       Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontFamily="{TemplateBinding FontFamily}"
                                       FontSize="{TemplateBinding FontSize}"
                                       FontWeight="{TemplateBinding FontWeight}"
                                       TextTrimming="CharacterEllipsis"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource SidebarItemHoverBackgroundBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource SidebarItemHoverForegroundBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource SidebarItemPressedBackgroundBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource SidebarItemSelectedForegroundBrush}"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource SidebarItemSelectedBackgroundBrush}"/>
                            <Setter TargetName="Indicator" Property="Background" Value="{StaticResource SidebarItemSelectedIndicatorBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource SidebarItemSelectedForegroundBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Root" Property="Background" Value="Transparent"/>
                            <Setter TargetName="Indicator" Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="{StaticResource SidebarItemDisabledForegroundBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
