<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="TagBase" TargetType="{x:Type Border}">
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="8,3"/>
        <Setter Property="Margin" Value="0,0,6,4"/>
    </Style>

    <Style x:Key="TagText" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="TopMostTag" TargetType="{x:Type Border}" BasedOn="{StaticResource TagBase}">
        <Setter Property="Background" Value="{StaticResource LightBlueBrush}"/>
    </Style>

    <Style x:Key="TransparentTag" TargetType="{x:Type Border}" BasedOn="{StaticResource TagBase}">
        <Setter Property="Background" Value="{StaticResource LightPurpleBrush}"/>
    </Style>

    <Style x:Key="ClickThroughTag" TargetType="{x:Type Border}" BasedOn="{StaticResource TagBase}">
        <Setter Property="Background" Value="{StaticResource LightOrangeBrush}"/>
    </Style>

    <Style x:Key="MiniTag" TargetType="{x:Type Border}" BasedOn="{StaticResource TagBase}">
        <Setter Property="Background" Value="{StaticResource LightGreenBrush}"/>
    </Style>

    <Style x:Key="NormalTag" TargetType="{x:Type Border}" BasedOn="{StaticResource TagBase}">
        <Setter Property="Background" Value="{StaticResource LightGrayBrush}"/>
    </Style>

    <Style x:Key="DangerTag" TargetType="{x:Type Border}" BasedOn="{StaticResource TagBase}">
        <Setter Property="Background" Value="{StaticResource LightRedBrush}"/>
    </Style>
</ResourceDictionary>
