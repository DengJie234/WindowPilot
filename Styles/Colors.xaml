<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="AppBackgroundColor">#F5F7FB</Color>
    <Color x:Key="SidebarBackgroundColor">#0F172A</Color>
    <Color x:Key="CardBackgroundColor">#FFFFFF</Color>
    <Color x:Key="PrimaryTextColor">#1F2937</Color>
    <Color x:Key="SecondaryTextColor">#6B7280</Color>
    <Color x:Key="MutedTextColor">#9CA3AF</Color>
    <Color x:Key="BorderColor">#E5E7EB</Color>
    <Color x:Key="PrimaryColor">#2563EB</Color>
    <Color x:Key="PrimaryHoverColor">#1D4ED8</Color>
    <Color x:Key="DangerColor">#DC2626</Color>
    <Color x:Key="DangerHoverColor">#B91C1C</Color>
    <Color x:Key="SuccessColor">#16A34A</Color>
    <Color x:Key="WarningColor">#F59E0B</Color>
    <Color x:Key="PurpleColor">#7C3AED</Color>
    <Color x:Key="OrangeColor">#EA580C</Color>

    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource AppBackgroundColor}"/>
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="{StaticResource SidebarBackgroundColor}"/>
    <SolidColorBrush x:Key="SidebarLogoForegroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SidebarSubtitleForegroundBrush" Color="#94A3B8"/>
    <SolidColorBrush x:Key="SidebarItemForegroundBrush" Color="#F1F5F9"/>
    <SolidColorBrush x:Key="SidebarItemHoverBackgroundBrush" Color="#1E293B"/>
    <SolidColorBrush x:Key="SidebarItemHoverForegroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SidebarItemSelectedBackgroundBrush" Color="#2563EB"/>
    <SolidColorBrush x:Key="SidebarItemSelectedForegroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SidebarItemSelectedIndicatorBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SidebarItemPressedBackgroundBrush" Color="#1D4ED8"/>
    <SolidColorBrush x:Key="SidebarItemDisabledForegroundBrush" Color="#64748B"/>
    <SolidColorBrush x:Key="SidebarFooterForegroundBrush" Color="#94A3B8"/>
    <SolidColorBrush x:Key="SidebarHoverBrush" Color="#1E293B"/>
    <SolidColorBrush x:Key="SidebarSelectedBrush" Color="#2563EB"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackgroundColor}"/>
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="{StaticResource PrimaryTextColor}"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource SecondaryTextColor}"/>
    <SolidColorBrush x:Key="MutedTextBrush" Color="{StaticResource MutedTextColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="{StaticResource PrimaryHoverColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="DangerHoverBrush" Color="{StaticResource DangerHoverColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="PurpleBrush" Color="{StaticResource PurpleColor}"/>
    <SolidColorBrush x:Key="OrangeBrush" Color="{StaticResource OrangeColor}"/>

    <SolidColorBrush x:Key="HoverBlueBrush" Color="#EFF6FF"/>
    <SolidColorBrush x:Key="SelectedBlueBrush" Color="#DBEAFE"/>
    <SolidColorBrush x:Key="LightBlueBrush" Color="#DBEAFE"/>
    <SolidColorBrush x:Key="LightPurpleBrush" Color="#EDE9FE"/>
    <SolidColorBrush x:Key="LightOrangeBrush" Color="#FFEDD5"/>
    <SolidColorBrush x:Key="LightGreenBrush" Color="#DCFCE7"/>
    <SolidColorBrush x:Key="LightRedBrush" Color="#FEE2E2"/>
    <SolidColorBrush x:Key="LightGrayBrush" Color="#F3F4F6"/>
</ResourceDictionary>
