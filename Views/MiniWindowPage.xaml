<UserControl x:Class="WindowPilot.Views.MiniWindowPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="24">
        <Border Style="{StaticResource Card}" Margin="0,0,0,16">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="{Binding Title}" Style="{StaticResource CardTitleText}"/>
                    <TextBlock Text="{Binding Description}" Style="{StaticResource CardCaptionText}" Margin="0,6,0,0"/>
                </StackPanel>
                <Button DockPanel.Dock="Right" Content="恢复全部小窗" Style="{StaticResource SecondaryButton}" IsEnabled="False"/>
            </DockPanel>
        </Border>
        <Border Style="{StaticResource Card}">
            <StackPanel HorizontalAlignment="Center" Margin="0,38">
                <TextBlock Text="◱" FontSize="46" Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock Text="当前没有小窗" Style="{StaticResource CardTitleText}" TextAlignment="Center"/>
                <TextBlock Text="将活动窗口设为小窗后，它会固定在屏幕角落并可一键恢复。" Style="{StaticResource CardCaptionText}" TextAlignment="Center" Margin="0,8,0,0"/>
                <Button Content="将活动窗口设为小窗" Style="{StaticResource PrimaryButton}" IsEnabled="False" HorizontalAlignment="Center" Margin="0,18,0,0"/>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
