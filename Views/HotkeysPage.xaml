<UserControl x:Class="WindowPilot.Views.HotkeysPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,16">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="快捷键设置" Style="{StaticResource CardTitleText}"/>
                    <TextBlock Text="你可以自定义 WindowPilot 的全局快捷键。注册失败时通常表示该组合键已被其他软件占用。"
                               Style="{StaticResource CardCaptionText}"
                               Margin="0,6,0,0"/>
                    <TextBlock Text="{Binding SummaryText}"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               FontWeight="SemiBold"
                               Margin="0,12,0,0"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Top">
                    <Button Content="全部重新注册" Style="{StaticResource SecondaryButton}" Command="{Binding ReRegisterAllCommand}" Margin="0,0,8,0"/>
                    <Button Content="恢复全部默认" Style="{StaticResource SecondaryButton}" Command="{Binding ResetAllCommand}" Margin="0,0,8,0"/>
                    <Button Content="保存设置" Style="{StaticResource PrimaryButton}" Command="{Binding SaveCommand}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource Card}">
            <DataGrid ItemsSource="{Binding Hotkeys}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="功能名称" Width="2.1*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" Foreground="{StaticResource PrimaryTextBrush}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Description}" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="当前快捷键" Binding="{Binding DisplayText}" Width="1.4*"/>

                    <DataGridTemplateColumn Header="状态" Width="1.5*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel VerticalAlignment="Center">
                                    <Border CornerRadius="12" Padding="8,3" HorizontalAlignment="Left">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{StaticResource LightGrayBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding StatusKind}" Value="Registered">
                                                        <Setter Property="Background" Value="{StaticResource LightGreenBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding StatusKind}" Value="Failed">
                                                        <Setter Property="Background" Value="{StaticResource LightRedBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding StatusKind}" Value="Conflict">
                                                        <Setter Property="Background" Value="{StaticResource LightOrangeBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Status}" FontSize="12" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding StatusKind}" Value="Registered">
                                                            <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding StatusKind}" Value="Failed">
                                                            <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding StatusKind}" Value="Conflict">
                                                            <Setter Property="Foreground" Value="{StaticResource OrangeBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                    <TextBlock Text="{Binding ErrorMessage}"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               FontSize="12"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="是否启用" Binding="{Binding EnabledText}" Width="0.8*"/>

                    <DataGridTemplateColumn Header="操作" Width="2*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Content="修改"
                                            Style="{StaticResource SecondaryButton}"
                                            Height="30"
                                            Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Margin="0,0,6,0"/>
                                    <Button Content="{Binding ToggleEnabledText}"
                                            Style="{StaticResource SecondaryButton}"
                                            Height="30"
                                            Command="{Binding DataContext.ToggleEnabledCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Margin="0,0,6,0"/>
                                    <Button Content="默认"
                                            Style="{StaticResource SecondaryButton}"
                                            Height="30"
                                            Command="{Binding DataContext.ResetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
