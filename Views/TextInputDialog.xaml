<Window x:Class="WindowPilot.Views.TextInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="输入"
        Width="420"
        Height="160"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="16">
        <TextBlock x:Name="PromptText" DockPanel.Dock="Top" TextWrapping="Wrap" Margin="0,0,0,10"/>
        <TextBox x:Name="ValueText" DockPanel.Dock="Top" Height="28" Margin="0,0,0,14"/>
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="确定" Width="82" Margin="0,0,8,0" IsDefault="True" Click="Ok_Click"/>
            <Button Content="取消" Width="82" IsCancel="True"/>
        </StackPanel>
    </DockPanel>
</Window>
