<UserControl x:Class="WindowPilot.Views.RulesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:WindowPilot.Converters">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="自动规则" Style="{StaticResource CardTitleText}"/>
                        <TextBlock Text="让特定窗口打开后自动置顶、移动或透明。" Style="{StaticResource CardCaptionText}" Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <CheckBox Content="暂停全部规则" IsChecked="{Binding RulesPaused}" VerticalAlignment="Center" Margin="0,0,18,0"/>
                        <Button Content="新建规则" Style="{StaticResource PrimaryButton}" Command="{Binding CreateRuleCommand}"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <ItemsControl ItemsSource="{Binding Rules}" Visibility="{Binding HasRules, Converter={StaticResource BoolToVisibility}}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                            <DockPanel>
                                <Border DockPanel.Dock="Left" Width="4" CornerRadius="2" Background="{StaticResource PrimaryBrush}" Margin="0,0,16,0"/>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Top" Margin="14,0,0,0">
                                    <Button Content="{Binding IsEnabled, Converter={StaticResource BoolToStatusText}, ConverterParameter=禁用|启用}"
                                            Style="{StaticResource SecondaryButton}"
                                            Command="{Binding DataContext.ToggleRuleEnabledCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Margin="0,0,8,0"/>
                                    <Button Content="删除"
                                            Style="{StaticResource DangerButton}"
                                            Command="{Binding DataContext.DeleteRuleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" Style="{StaticResource CardTitleText}"/>
                                    <WrapPanel Margin="0,10,0,0">
                                        <Border>
                                            <Border.Style>
                                                <Style TargetType="{x:Type Border}" BasedOn="{StaticResource NormalTag}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsValid}" Value="False">
                                                            <Setter Property="Background" Value="{StaticResource LightRedBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource LightGreenBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding StatusText}" Style="{StaticResource TagText}"/>
                                        </Border>
                                        <Border Style="{StaticResource TopMostTag}">
                                            <TextBlock Text="{Binding ActionDisplay}" Style="{StaticResource TagText}"/>
                                        </Border>
                                    </WrapPanel>
                                    <TextBlock Text="{Binding ValidationMessage}"
                                               Foreground="{StaticResource DangerBrush}"
                                               FontSize="12"
                                               Margin="0,8,0,0"/>
                                    <TextBlock Text="{Binding MatchSummary}"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               FontSize="13"
                                               Margin="0,8,0,0"/>
                                    <UniformGrid Columns="4" Margin="0,14,0,0">
                                        <StackPanel>
                                            <TextBlock Text="进程名" Style="{StaticResource InfoLabelText}"/>
                                            <TextBlock Text="{Binding ProcessName, TargetNullValue=-}" Style="{StaticResource InfoValueText}"/>
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="标题关键词" Style="{StaticResource InfoLabelText}"/>
                                            <TextBlock Text="{Binding TitleContains, TargetNullValue=-}" Style="{StaticResource InfoValueText}"/>
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="优先级" Style="{StaticResource InfoLabelText}"/>
                                            <TextBlock Text="{Binding Priority}" Style="{StaticResource InfoValueText}"/>
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="上次执行" Style="{StaticResource InfoLabelText}"/>
                                            <TextBlock Text="{Binding LastExecutedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Style="{StaticResource InfoValueText}"/>
                                        </StackPanel>
                                    </UniformGrid>
                                </StackPanel>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border Style="{StaticResource Card}" Visibility="{Binding HasRules, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                <StackPanel HorizontalAlignment="Center" Margin="0,32">
                    <TextBlock Text="⚙" FontSize="42" Foreground="{StaticResource PrimaryBrush}" TextAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="还没有自动规则" Style="{StaticResource CardTitleText}" TextAlignment="Center"/>
                    <TextBlock Text="你可以创建规则，让某些窗口打开后自动置顶、移动或透明。" Style="{StaticResource CardCaptionText}" TextAlignment="Center" Margin="0,8,0,0"/>
                    <Button Content="创建第一条规则" Style="{StaticResource PrimaryButton}" Command="{Binding CreateRuleCommand}" HorizontalAlignment="Center" Margin="0,18,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
