<UserControl x:Class="WindowPilot.Views.GroupsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="24">
        <Border Style="{StaticResource Card}" Margin="0,0,0,16">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="{Binding Title}" Style="{StaticResource CardTitleText}"/>
                    <TextBlock Text="{Binding Description}" Style="{StaticResource CardCaptionText}" Margin="0,6,0,0"/>
                </StackPanel>
                <Button DockPanel.Dock="Right" Content="新建分组" Style="{StaticResource PrimaryButton}" IsEnabled="False"/>
            </DockPanel>
        </Border>
        <Border Style="{StaticResource Card}">
            <StackPanel HorizontalAlignment="Center" Margin="0,38">
                <TextBlock Text="▣" FontSize="46" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock Text="还没有窗口分组" Style="{StaticResource CardTitleText}" TextAlignment="Center"/>
                <TextBlock Text="分组可以把一组窗口作为一个工作场景批量最小化、恢复或置顶。" Style="{StaticResource CardCaptionText}" TextAlignment="Center" Margin="0,8,0,0"/>
                <Button Content="新建分组" Style="{StaticResource PrimaryButton}" IsEnabled="False" HorizontalAlignment="Center" Margin="0,18,0,0"/>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
