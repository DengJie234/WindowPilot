<UserControl x:Class="WindowPilot.Views.LayoutsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:WindowPilot.Converters">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="布局管理" Style="{StaticResource CardTitleText}"/>
                        <TextBlock Text="保存当前桌面窗口布局，并在需要时恢复位置、大小和状态。" Style="{StaticResource CardCaptionText}" Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="保存当前布局" Style="{StaticResource PrimaryButton}" Command="{Binding SaveCurrentLayoutCommand}" Margin="0,0,8,0"/>
                        <Button Content="恢复选中布局" Style="{StaticResource SecondaryButton}" Command="{Binding RestoreLayoutCommand}" Margin="0,0,8,0"/>
                        <Button Content="删除" Style="{StaticResource DangerButton}" Command="{Binding DeleteLayoutCommand}"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <ListBox ItemsSource="{Binding Layouts}"
                     SelectedItem="{Binding SelectedLayout, Mode=TwoWay}"
                     BorderThickness="0"
                     Background="Transparent"
                     Visibility="{Binding HasLayouts, Converter={StaticResource BoolToVisibility}}">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="{x:Type ListBoxItem}">
                        <Setter Property="Margin" Value="0,0,16,16"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                    <Border x:Name="Root"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{StaticResource PrimaryBrush}"
                                            BorderThickness="0"
                                            CornerRadius="12">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Root" Property="BorderThickness" Value="2"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Card}" Width="340">
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" Style="{StaticResource CardTitleText}" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding Summary}" Style="{StaticResource CardCaptionText}" Margin="0,4,0,14"/>
                                <UniformGrid Columns="2">
                                    <TextBlock Text="创建时间" Style="{StaticResource InfoLabelText}"/>
                                    <TextBlock Text="{Binding CreatedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Style="{StaticResource InfoValueText}"/>
                                    <TextBlock Text="窗口数量" Style="{StaticResource InfoLabelText}" Margin="0,8,0,0"/>
                                    <TextBlock Text="{Binding Items.Count}" Style="{StaticResource InfoValueText}" Margin="0,8,0,0"/>
                                </UniformGrid>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Border Style="{StaticResource Card}" Visibility="{Binding HasLayouts, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                <StackPanel HorizontalAlignment="Center" Margin="0,32">
                    <TextBlock Text="▦" FontSize="42" Foreground="{StaticResource PrimaryBrush}" TextAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="还没有保存任何窗口布局" Style="{StaticResource CardTitleText}" TextAlignment="Center"/>
                    <TextBlock Text="你可以先调整好桌面窗口，然后点击保存当前布局。" Style="{StaticResource CardCaptionText}" TextAlignment="Center" Margin="0,8,0,0"/>
                    <Button Content="保存当前布局" Style="{StaticResource PrimaryButton}" Command="{Binding SaveCurrentLayoutCommand}" HorizontalAlignment="Center" Margin="0,18,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
