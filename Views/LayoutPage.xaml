<UserControl x:Class="WindowPilot.Views.LayoutPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="保存所有可见窗口" Click="SaveAll_Click" Padding="12,7" Margin="0,0,8,0"/>
            <Button Content="保存选中窗口" Click="SaveSelected_Click" Padding="12,7" Margin="0,0,8,0"/>
            <Button Content="恢复布局" Click="Restore_Click" Padding="12,7" Margin="0,0,8,0"/>
            <Button Content="重命名" Click="Rename_Click" Padding="12,7" Margin="0,0,8,0"/>
            <Button Content="删除" Click="Delete_Click" Padding="12,7"/>
        </StackPanel>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>
            <ListBox x:Name="LayoutsList" Grid.Column="0" DisplayMemberPath="Name" SelectionChanged="LayoutsList_SelectionChanged"/>
            <DockPanel Grid.Column="1" Margin="14,0,0,0">
                <TextBlock DockPanel.Dock="Top" Text="布局窗口项" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <DataGrid x:Name="LayoutItemsGrid" AutoGenerateColumns="False" IsReadOnly="True" Height="260" DockPanel.Dock="Top">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="进程" Binding="{Binding ProcessName}" Width="120"/>
                        <DataGridTextColumn Header="标题" Binding="{Binding WindowTitle}" Width="*"/>
                        <DataGridTextColumn Header="类名" Binding="{Binding ClassName}" Width="140"/>
                        <DataGridTextColumn Header="位置" Binding="{Binding State.X}" Width="70"/>
                        <DataGridTextColumn Header="大小" Binding="{Binding State.Width}" Width="70"/>
                        <DataGridTextColumn Header="显示器" Binding="{Binding MonitorDeviceName}" Width="140"/>
                    </DataGrid.Columns>
                </DataGrid>
                <TextBox x:Name="LayoutLogText" Margin="0,10,0,0" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
            </DockPanel>
        </Grid>
    </DockPanel>
</UserControl>
