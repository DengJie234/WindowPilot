<Window x:Class="WindowPilot.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="False"
        ResizeMode="NoResize"
        Topmost="True"
        Focusable="False"
        IsHitTestVisible="False"
        Opacity="0.76"
        Width="200"
        Height="120">
    <Grid IsHitTestVisible="False">
        <Border x:Name="FrameBorder"
                BorderBrush="#2563EB"
                BorderThickness="2"
                CornerRadius="6"
                Background="Transparent"/>
        <Border x:Name="Badge"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Background="#C1121F"
                CornerRadius="0,0,0,6"
                Padding="8,3"
                Visibility="Collapsed">
            <TextBlock x:Name="BadgeText"
                       Foreground="White"
                       FontWeight="SemiBold"
                       FontSize="12"/>
        </Border>
    </Grid>
</Window>
